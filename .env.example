# ─── Next.js ─────────────────────────────────────────────────────────────────
# Canonical URL of the site (used by Supabase auth redirects and metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find both values at: Supabase Dashboard → Settings → API

# Anon (public) key — safe to expose to the browser; enforced by RLS policies
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — server-only (Route Handlers, migrations). NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Zoho SMTP ────────────────────────────────────────────────────────────────
# App password (NOT your account password).
# Generate at: Zoho Account → Security → App Passwords
ZOHO_EMAIL=your-zoho-email@yourdomain.com
ZOHO_PASSWORD=your-zoho-app-password
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587

# Internal inbox that receives contact form notifications
NOTIFICATION_EMAIL=your-notification-email@yourdomain.com
